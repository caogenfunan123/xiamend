<%
function plainExcerpt(post){
  var html = post.excerpt || post.content || '';
  var text = html
    .replace(/<[^>]+>/g, ' ')
    .replace(/&nbsp;/g, ' ')
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&#x2F;/g, '/')
    .replace(/\s+/g, ' ')
    .trim();
  if (!text) return '';
  return text.length > 140 ? text.substring(0, 140) + '...' : text;
}
%>
<div class="posts">
  <% page.posts.each(function(post){ %>
    <article class="post card">
      <h2 class="post-title"><a href="<%= url_for(post.path) %>"><%= post.title %></a></h2>
      <div class="post-meta">
        <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, 'YYYY年MM月DD日') %></time>
        <% if (post.categories && post.categories.length) { %>
          <span class="dot">·</span>
          <span class="post-category"><%- list_categories(post.categories, {show_count:false, style:'none', separator:' / '}) %></span>
        <% } %>
        <% if (post.tags && post.tags.length) { %>
          <span class="dot">·</span>
          <span class="post-tags"><%- list_tags(post.tags, {show_count:false, style:'none', separator:' / '}) %></span>
        <% } %>
      </div>
      <div class="post-excerpt"><%= plainExcerpt(post) %></div>
      <a class="read-more" href="<%= url_for(post.path) %>">阅读全文 →</a>
    </article>
  <% }) %>

  <% if (page.total > 1) { %>
    <nav class="pagination">
      <% if (page.prev) { %><a class="prev" href="<%= url_for(page.prev_link) %>">← 上一页</a><% } %>
      <span class="page-num"><%= page.current %> / <%= page.total %></span>
      <% if (page.next) { %><a class="next" href="<%= url_for(page.next_link) %>">下一页 →</a><% } %>
    </nav>
  <% } %>
</div>
