<div class="posts">
  <% page.posts.each(function(post) { %>
    <article class="post">
      <h2 class="post-title"><a href="<%= url_for(post.path) %>"><%= post.title %></a></h2>
      <div class="post-meta">
        <time><%= date(post.date, 'YYYY年MM月DD日') %></time>
        <% if(post.categories && post.categories.length) { %>
          <span class="post-category"> · <%= post.categories.map(function(cat){ return cat.name; }).join(' > ') %></span>
        <% } %>
        <% if(post.tags && post.tags.length) { %>
          <span class="post-tags"> · 标签：<%= post.tags.map(function(tag){ return tag.name; }).join(', ') %></span>
        <% } %>
      </div>
      <div class="post-excerpt">
        <%- post.excerpt ? post.excerpt : post.content.substring(0, 200) + '...' %>
      </div>
      <a class="read-more" href="<%= url_for(post.path) %>">阅读全文 →</a>
    </article>
  <% }) %>

  <% if (page.prev || page.next) { %>
    <nav class="pagination">
      <% if (page.prev) { %><a class="prev" href="<%= url_for(page.prev_link) %>">← 上一页</a><% } %>
      <% if (page.next) { %><a class="next" href="<%= url_for(page.next_link) %>">下一页 →</a><% } %>
    </nav>
  <% } %>
</div>