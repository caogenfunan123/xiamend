<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title ? page.title + ' | ' : '' %><%= config.title %></title>
  <meta name="description" content="<%= page.description || config.description %>">
  <meta name="theme-color" content="#667eea">
  <link rel="stylesheet" href="<%= url_for('/css/style.css') %>">
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <div class="brand">
        <h1 class="site-title"><a href="<%= url_for('/') %>"><%= config.title %></a></h1>
        <% if (config.subtitle) { %><p class="site-subtitle"><%= config.subtitle %></p><% } %>
      </div>
      <nav class="site-nav">
        <a href="<%= url_for('/') %>">首页</a>
        <a href="<%= url_for('/archives/') %>">归档</a>
        <a href="<%= url_for('/tags/') %>">标签</a>
        <a href="<%= url_for('/categories/') %>">分类</a>
        <a href="<%= url_for('/2026/07/15/关于我/') %>">关于</a>
      </nav>
    </div>
  </header>

  <main class="container main-content">
    <%- body %>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>&copy; <%= date(Date.now(), 'YYYY') %> <%= config.author || config.title %>. Powered by <a href="https://hexo.io" target="_blank" rel="noopener">Hexo</a> · Hosted on Cloudflare Pages.</p>
    </div>
  </footer>
</body>
</html>
