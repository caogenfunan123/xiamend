<article class="post">
  <h1 class="post-title"><%= page.title %></h1>
  <div class="post-meta">
    <time><%= date(page.date, 'YYYY年MM月DD日') %></time>
    <% if(page.categories && page.categories.length) { %>
      <span class="post-category"> · <%= page.categories.map(function(cat){ return cat.name; }).join(' > ') %></span>
    <% } %>
    <% if(page.tags && page.tags.length) { %>
      <span class="post-tags"> · 标签：<%= page.tags.map(function(tag){ return tag.name; }).join(', ') %></span>
    <% } %>
  </div>
  <div class="post-content">
    <%- page.content %>
  </div>
  <a class="back-home" href="/">← 返回首页</a>
</article>